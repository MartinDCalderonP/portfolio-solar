---
const hashes: string[] = [];

for (let i = 0; i < 4; i++) {
  const top = Math.random() * 60 + 10;
  const delay = i * 3;
  const duration = Math.random() * 4 + 6;

  hashes.push(
    `<div
      class="spaceship"
      style="
        top: ${top}%;
        animation-delay: ${delay}s;
        animation-duration: ${duration}s;
      "
    >🚀</div>`,
  );
}
---

<div class="spaceship-container" set:html={hashes.join('')} />

<style>
  .spaceship-container {
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    position: fixed;
    z-index: var(--z-spaceship);
  }

  .spaceship {
    animation: fly linear infinite;
    font-size: 24px;
    position: absolute;
    right: -60px;
    transform: rotate(-15deg);
  }

  @keyframes fly {
    0% {
      transform: translateX(0) rotate(-15deg);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateX(calc(-100vw - 80px)) rotate(-15deg);
      opacity: 0;
    }
  }
</style>
