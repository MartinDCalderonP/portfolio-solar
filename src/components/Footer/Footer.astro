---
import './Footer.css';

const PORTFOLIO_URL = 'https://portfolio-martindcalderonp.vercel.app/';
---

<footer class="footer">
  <div class="footer-line">© <span id="footer-year" /> — Todos los derechos reservados</div>
  <div class="footer-separator" />
  <div class="footer-line">
    Diseñado y desarrollado por
    <a class="footer-link" href={PORTFOLIO_URL} target="_blank" rel="noopener noreferrer">Martín Calderón
    </a>
  </div>
</footer>

<script>
  const yearEl = document.getElementById('footer-year');
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>
