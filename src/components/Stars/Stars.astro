---
const DELAY_MAX = 5;
const DURATION_MAX = 5;
const DURATION_MIN = 2;
const POSITION_RANGE = 100;
const SIZE_MAX = 4;
const SIZE_MIN = 1;
const STAR_COUNT = 120;

const generateStars = (): string => {
  const stars: string[] = [];

  for (let i = 0; i < STAR_COUNT; i++) {
    const x = Math.random() * POSITION_RANGE;
    const y = Math.random() * POSITION_RANGE;
    const size = Math.random() * (SIZE_MAX - SIZE_MIN) + SIZE_MIN;
    const delay = Math.random() * DELAY_MAX;
    const duration = Math.random() * (DURATION_MAX - DURATION_MIN) + DURATION_MIN;

    stars.push(
      `<div
        class="star"
        style="
          left: ${x}%;
          top: ${y}%;
          width: ${size}px;
          height: ${size}px;
          animation-delay: ${delay}s;
          animation-duration: ${duration}s;
        "
      ></div>`,
    );
  }

  return stars.join('');
};
---

<div
  class="stars-container"
  set:html={generateStars()}
/>

<style is:global>
  .stars-container {
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    position: fixed;
    z-index: var(--z-stars);
  }

  .star {
    animation: twinkle ease-in-out infinite alternate;
    background: white;
    border-radius: 50%;
    position: absolute;
  }

  @keyframes twinkle {
    0% {
      opacity: 0.2;
    }
    100% {
      opacity: 1;
    }
  }
</style>
