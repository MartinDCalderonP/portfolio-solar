---
import PlanetIcon from '../PlanetIcon/PlanetIcon.astro';
import type { PlanetContent } from '../../data/portfolio';
import './Planet.css';
import './Sol.css';

interface Props {
  planet: PlanetContent;
  index: number;
}

const {
  planet,
  index,
} = Astro.props;

const { id, name, colorVar, size, orbitVar } = planet;

const orbitRadiusValue = orbitVar;
const durationDefault = (index + 1) * 5 + 8;
const selfDuration = Math.max(2, 12 - index);
const isMarte = id === 'marte';
const isSol = id === 'sol';
---

{
  isSol ? (
    <div class="sol" data-planet-id={id}>
      <div class="sol-glow" />
      <div class="sol-core">
        <span class="sol-text">M</span>
      </div>
      <span class="sol-label">{name}</span>
    </div>
  ) : (
    <div
      class="orbit"
      style={{
        '--orbit-radius': orbitRadiusValue,
        '--orbit-duration': `${durationDefault}s`,
        zIndex: `${10 - index}`,
      }}
    >
      <div
        class="planet-wrapper"
        data-planet-id={id}
        style={{
          '--planet-size': size,
        }}
      >
        <div
          class={`planet-dot${isMarte ? ' marte' : ''}`}
          style={{
            '--planet-color': colorVar,
            '--self-duration': `${selfDuration}s`,
          }}
        >
          <PlanetIcon planetId={id} />
        </div>
        <span class="planet-label">{name}</span>
      </div>
    </div>
  )
}
